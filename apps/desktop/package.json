{
  "name": "@pdf-intelligence/desktop",
  "version": "0.1.0",
  "description": "Offline-first PDF intelligence desktop application",
  "author": "PDF Intelligence Contributors",
  "private": true,
  "type": "module",
  "main": "dist/electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "clean": "powershell -ExecutionPolicy Bypass -Command \"Remove-Item -Recurse -Force dist -ErrorAction SilentlyContinue\"",
    "build": "npm run clean && tsc -p tsconfig.json && vite build",
    "test": "vitest run --root . --exclude tests/e2e/**",
    "test:e2e": "playwright test --config playwright.config.ts",
    "test:package": "playwright test --config playwright.package.config.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "package:dir": "npm run build && powershell -ExecutionPolicy Bypass -File ../../scripts/build-sidecar.ps1 && electron-builder --dir"
  },
  "dependencies": {
    "@pdf-intelligence/contracts": "0.1.0",
    "pdfjs-dist": "5.3.93",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "uuid": "11.1.1",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/react": "19.1.8",
    "@types/react-dom": "19.1.6",
    "@vitejs/plugin-react": "4.6.0",
    "@playwright/test": "1.57.0",
    "concurrently": "9.2.0",
    "cross-env": "7.0.3",
    "electron": "43.1.1",
    "electron-builder": "26.15.3",
    "typescript": "5.8.3",
    "vite": "7.3.6",
    "vitest": "3.2.7",
    "wait-on": "8.0.3"
  },
  "build": {
    "appId": "com.pdfintelligence.desktop",
    "productName": "PDF Intelligence",
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../../dist/sidecar",
        "to": "sidecar"
      }
    ],
    "directories": {
      "output": "../../installers/dev"
    },
    "win": {
      "target": "dir",
      "signAndEditExecutable": false
    }
  }
}
